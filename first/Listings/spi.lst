    3          /*--- 全局变量和状态标志，用于主循环与中断服务程序(ISR)通信 ---*/
    4          // volatile 关键字确保编译器不对这些变量进行优化，因为它们在中断中被修改
    5          sbit LED = P1^1; 
    6          
    7          void SPI_Init(void)                             //初始化
    8                  {
    9   1                      LED = 1; 
   10   1                      SS = 1; 
   11   1                      P_SW1 &= 0XFC;          //???? ??00             引脚选择将低两位写为0
   12   1                                                              //SS MOSI MISO SCLK  P5.4 P1.3 P1.4 P1.5 
   13   1                      
   14   1                      SPCTL = 0X50;           //模式配置 SSIG==0,MSTR==0固定为主机模式
   15   1                      SPCTL |= 0X40;      //最后再使能SPI防止数据未使能读写就已经结束
   16   1                      
   17   1                      SCLK = 0;                       //引脚初始化
   18   1                      
   19   1                      SPSTAT = 0xC0;  // 写1清除SPIF和WCOL标志位
   20   1                      ESPI = 1;       // 使能SPI中断 (STC32G中SPI中断的使能位)
   21   1                      //EA = 1;         // 开启全局中断 总中断会再主函数打开
