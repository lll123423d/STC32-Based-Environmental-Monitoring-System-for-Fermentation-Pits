   32          void SPI_WriteByte(unsigned char dat)           //写入一个字节
   33                  {
   34   1              SS = 0; //拉低从机SS管脚 
   35   1              SPDAT = dat; //发送测试数据 
   36   1              while (!(SPSTAT & 0x80)); //查询完成标志 
   37   1              SPSTAT = 0xc0; //清中断标志 
   38   1              SS = 1; //拉高从机的SS管脚 
   39   1              LED = !LED; //测试端口
   40   1              }
   41                  
   42          /**
   43            * @brief  通过SPI读取一个字节的数据
   44            * @param  无
   45            * @retval 读取到的字节数据
   46            * @note   此函数使用查询方式，会阻塞直到数据传输完成
   47            **/
   48          unsigned char SPI_ReadByte(void)
   49          {
   50   1         unsigned char received_data;
   51   1          
   52   1          SS = 0;              // 拉低从机SS管脚，开始传输
   53   1          SPDAT = 0xFF;        // 发送虚拟数据0xFF以产生时钟信号
   54   1          while (!(SPSTAT & 0x80)); // 等待传输完成
   55   1          received_data = SPDAT; // 读取接收到的数据
   56   1          SPSTAT = 0xC0;       // 清除SPIF和WCOL标志位
   57   1          SS = 1;              // 拉高从机的SS管脚，结束传输
   58   1          
