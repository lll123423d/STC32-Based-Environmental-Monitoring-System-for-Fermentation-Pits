   20          void OLED_WR_Byte(unsigned char dat, unsigned char cmd)
   21          {                                 
   22   1          // 1. ПИЙиЦГDCТэҪЕЈЁКэҫЭ/ГьБоСЎФсЈ©
   23   1          if(cmd) {
   24   2              OLED_DC=1;   // ЧјұёРҙИлКэҫЭ
   25   2          } else {
   26   2              OLED_DC=0;   // ЧјұёРҙИлГьБо
   27   2          }
   28   1      
   29   1          
   30   1          // 2. ҝӘКјSPIҙ«Кд
   31   1          SS = 0;             // АӯөНSSЈ¬ҝӘКјҙ«Кд
   32   1          SPDAT = dat;        // ·ўЛНКэҫЭ
   33   1          while (!(SPSTAT & 0x80)); // өИҙэҙ«КдНкіЙ
   34   1          SPSTAT = 0xC0;      // ЗеіэұкЦҫО»
   35   1          SS = 1;             // АӯёЯSSЈ¬ҪбКшҙ«Кд
   36   1         OLED_DC=1;
   37   1      }
