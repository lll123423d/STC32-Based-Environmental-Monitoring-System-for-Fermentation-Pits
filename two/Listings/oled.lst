  449          //========================================================================
  450          void OLED_BuffShowString(unsigned char x,unsigned char y,char *s,u8 mode)
  451          {
  452   1          char s_num[2];
  453   1              while(*s != '\0')       //字符串不为空，循环
  454   1              {
  455   2              if ((unsigned char)*s < 0x80)     //根据输入数据的大小判断是字符还是汉字，
  456   2              {
  457   3                  OLED_BuffShowChar(x,y,*s,mode);
  458   3                  x+=8;
  459   3                  s++;
  460   3              }
  461   2              else
  462   2              {
  463   3                  s_num[0] = *s ;
  464   3                  s_num[1] = *(s+1) ;
  465   3                  OLED_BuffShowGBK(x,y,s_num,mode);
  466   3                  x+=16;
  467   3                  s+=2;
  468   3              }
  469   2                      if(x>127)
  470   2              {
  471   3                  x=0;
  472   3                  y+=2;
  473   3              }
  474   2              }       
  475   1      }
